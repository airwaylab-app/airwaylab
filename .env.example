
# PostHog Analytics (Session Replay + Conversion Events)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Discord Community Integration
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_SUPPORTER_ROLE_ID=
DISCORD_CHAMPION_ROLE_ID=
DISCORD_REDIRECT_URI=https://airwaylab.app/api/auth/discord/callback
DISCORD_INVITE_URL=
NEXT_PUBLIC_DISCORD_INVITE_URL=

# Gmail OAuth2 (Feedback Processor — AIR-759)
# OAuth2 credentials for dev@airwaylab.app to create Gmail drafts from feedback.
# Obtain via Google Cloud Console > APIs & Services > Credentials.
# Use OAuth2 Playground (https://developers.google.com/oauthplayground) to get refresh token.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# CAN-SPAM Act compliance: physical mailing address shown in re-engagement email footers.
# Required by 16 CFR Part 316. Set to the sender's valid physical postal address.
SENDER_PHYSICAL_ADDRESS=
