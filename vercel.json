    },
    {
      "path": "/api/cron/feedback-processor",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/db-integrity-check",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/discord-strategy-digest",
      "schedule": "0 8 * * *"
