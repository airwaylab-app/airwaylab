{
  "github": {
    "silent": true
  },
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- app/ components/ lib/ workers/ public/ package.json package-lock.json proxy.ts next.config.mjs instrumentation.ts instrumentation-client.ts sentry.server.config.ts sentry.edge.config.ts tailwind.config.ts postcss.config.mjs vercel.json",
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/monitor",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/discord-sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 18 * * 0"
    },
    {
      "path": "/api/cron/ai-monitor",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/subscription-drift",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/feedback-processor",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/db-integrity-check",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/discord-strategy-digest",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/discord-weekly-digest",
      "schedule": "0 8 * * 1"
    }
  ]
}

